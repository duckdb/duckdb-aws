# name: test/sql/rds/aws_rds_connect.test
# description: test attaching an RDS instance discovered via DescribeDBInstances + IAM auth
# group: [rds]

require aws

require parquet

# The 'aws' secret type is registered by httpfs.
require httpfs

require postgres_scanner

require-env RDS_AVAILABLE 1

statement ok
SET allow_persistent_secrets=false

statement ok
CREATE SECRET rds_creds (
    TYPE aws,
    PROVIDER credential_chain,
    PROFILE 'personal',
    CHAIN 'config',
    REGION 'eu-central-1',
);

statement ok
ATTACH 'attach-connect-test' AS rds_db (TYPE RDS);

statement ok
select * from (show all tables) where database = 'rds_db';

# The dev database should expose exactly 7 tables.
query I
SELECT count(*) FROM (SHOW ALL TABLES) WHERE database = 'rds_db';
----
1

query IIIIIIII
select * from rds_db.public.dummy_users limit 10;
