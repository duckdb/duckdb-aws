# Then it will call GetClusterCredentialsWithIAM to get a needed username and password
statement ok
ATTACH 'redshift-cluster-1' AS redshift_db (TYPE postgres, SECRET redshift_creds);

statement ok
select * from (show all tables) where database = 'redshift_db';


# The dev database should expose exactly 7 tables.
query I
SELECT count(*) FROM (SHOW ALL TABLES) WHERE database = 'redshift_db';
----
7

statement ok
DETACH redshift_db

statement ok
DROP SECRET redshift_creds
