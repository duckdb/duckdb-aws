# name: test/sql/env/proxy/aws_secret_http_proxy.test
# description: test that http_proxy params can be set for credential_chain secrets
# group: [proxy]

require aws

require httpfs

require-env HTTP_PROXY_PUBLIC 1

require-env DUCKDB_S3_ENDPOINT

require-env DUCKDB_S3_USE_SSL

require-env S3_TEST_SERVER_AVAILABLE 1

# statement ok
CREATE SECRET http_proxy_chain_secret (
    TYPE S3,
    PROVIDER credential_chain,
    HTTP_PROXY 'localhost:8878',
    region 'us-east-1'
);

statement ok
SET ca_cert_file = '~/.mitmproxy/mitmproxy-ca-cert.pem';

statement ok
COPY (select 123 as column) to 's3://test-bucket/test_basic/test_proxy.csv';

query I
SELECT * FROM 's3://test-bucket/test_basic/test_proxy.csv';
----
123

# Proxy should see a GET request to a csv file
query I
SELECT regexp_matches(
    substr((SELECT content FROM read_text("mitmproxy.log")), (SELECT log_length FROM logs_tracker) + 1),
    'GET.*\/test_base\/test.*paarquet'
);
----
true