# name: test/sql/env/proxy/aws_secret_http_proxy_with_auth.test
# description: test that http_proxy params can be set for credential_chain secrets
# group: [proxy]

require aws

require httpfs

require-env HTTP_PROXY_PUBLIC

require-env DUCKDB_S3_ENDPOINT

require-env AWS_ACCESS_KEY_ID

require-env S3_TEST_SERVER_AVAILABLE 1

require-env DUCKDB_S3_USE_SSL 0

require-env AWS_SECRET_ACCESS_KEY

set ignore_error_messages

statement ok
SET s3_url_style = 'path';

# Keep track of where the log file will start writing, as proxy logs from previous tests are irrelevant
statement ok
CREATE TABLE logs_tracker AS SELECT len(content) AS log_length FROM read_text('mitmproxy.log');


statement ok
create or replace secret http_proxy_chain_secret (
  TYPE S3,
  PROVIDER 'credential_chain',
  HTTP_PROXY '${HTTP_PROXY_PUBLIC}',
  REGION 'eu-west-2',
  ENDPOINT '${DUCKDB_S3_ENDPOINT}',
  HTTP_PROXY_USERNAME 'admin',
  HTTP_PROXY_PASSWORD 'password'
);

statement ok
SET ca_cert_file = '~/.mitmproxy/mitmproxy-ca-cert.pem';

statement ok
COPY (select 123 as column) to 's3://test-bucket/test_basic/test_proxy_auth.csv';

query I
SELECT * FROM 's3://test-bucket/test_basic/test_proxy_auth.csv';
----
123

query I
SELECT regexp_matches(
    substr((SELECT content FROM read_text("mitmproxy.log")), (SELECT log_length FROM logs_tracker) + 1),
    'GET.*\/test_basic\/test_proxy_auth.*csv'
);
----
true


