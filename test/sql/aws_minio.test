# name: test/sql/aws_minio.test
# description: test aws extension with minio test server
# group: [sql]

require aws

require httpfs

require-env DUCKDB_S3_ENDPOINT

require-env DUCKDB_S3_USE_SSL

require-env S3_TEST_SERVER_AVAILABLE 1

require-env AWS_CONFIG_FILE

require-env AWS_SHARED_CREDENTIALS_FILE

set ignore_error_messages

statement ok
CREATE PERSISTENT SECRET (
    TYPE S3,
    PROVIDER credential_chain,
    ENDPOINT '{DUCKDB_S3_ENDPOINT}',
    USE_SSL '{DUCKDB_S3_USE_SSL}'
)

statement ok
COPY (select 123 as column) to 's3://test-bucket/test_basic/test.csv';

query I
SELECT * FROM 's3://test-bucket/test_basic/test.csv';
----
123

# set a faulty region value on purpose
statement ok
CREATE OR REPLACE PERSISTENT SECRET (
  TYPE S3,
  PROVIDER credential_chain,
  REGION 'the-moon-123',
  ENDPOINT '{DUCKDB_S3_ENDPOINT}',
  USE_SSL '{DUCKDB_S3_USE_SSL}'
)

# Malformed region: throws 400
statement error
SELECT * FROM 's3://test-bucket/test_basic/test.csv';
----
HTTP 400

# reset region
statement ok
CREATE OR REPLACE PERSISTENT SECRET (
TYPE S3,
PROVIDER credential_chain,
PROFILE 'minio-testing-invalid',
REGION 'eu-west-1',
ENDPOINT '{DUCKDB_S3_ENDPOINT}',
USE_SSL '{DUCKDB_S3_USE_SSL}'
)

# now http 403 is thrown for invalid credentials
statement error
SELECT * FROM 's3://test-bucket/test_basic/test.csv';
----
HTTP 403

# Reset to a working secret
statement ok
CREATE OR REPLACE PERSISTENT SECRET (
TYPE S3,
PROVIDER credential_chain,
ENDPOINT '{DUCKDB_S3_ENDPOINT}',
USE_SSL '{DUCKDB_S3_USE_SSL}'
)

# Query still works
query I
SELECT * FROM 's3://test-bucket/test_basic/test.csv';
----
123


# testing something
query I
SELECT value FROM duckdb_settings() WHERE name = 's3_secret_access_key';
----
NULL