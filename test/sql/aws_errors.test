# name: test/sql/aws_errors.test
# description: test aws extension
# group: [sql]

require no_extension_autoloading "EXPECTED: Test relies on explcit INSTALL and LOAD"

# Before we load the extension, the credential_chain provider does not exist
statement error
create secret s1 (type s3, provider 'credential_chain');
----
Invalid Input Error: Secret provider 'credential_chain' for type 's3' does not exist, but it exists in the aws extension.

# Require statement will ensure this test is run with this extension loaded
require aws

# aws supplies the credential_chain provider, but the s3 secret TYPE itself is
# registered by httpfs - so without httpfs the secret still cannot be stored.
# (validation 'none' skips real credential resolution so this is deterministic.)
statement error
create secret s1 (type s3, provider 'credential_chain', validation 'none');
----
Secret type 's3' does not exist, but it exists in the httpfs extension

require httpfs

# With both the type (httpfs) and provider (aws) available, and validation
# disabled so no real AWS credentials are needed, the secret is created.
statement ok
create secret s1 (type s3, provider 'credential_chain', validation 'none');
